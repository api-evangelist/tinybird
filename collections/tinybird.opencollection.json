            "params": [
              {
                "name": "name",
                "value": "",
                "type": "query",
                "description": "Name of the target data source"
              },
              {
                "name": "wait",
                "value": "",
                "type": "query",
                "description": "Wait for the ingestion to complete before returning"
              }
            ],
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Ingest NDJSON events with a simple HTTP POST request to a data source."
        }
      ]
