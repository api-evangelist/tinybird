      "type": "string",
      "description": "Cluster assignment for the data source"
    },
    {
      "name": "tags",
      "type": "object",
      "description": "Key-value metadata tags"
    },
    {
      "name": "schema",
      "type": "string",
      "description": "ClickHouse schema definition"
    },
    {
      "name": "created_at",
      "type": "string (ISO 8601)",
      "description": "Creation timestamp"
    },
    {
      "name": "updated_at",
